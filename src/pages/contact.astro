---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const socials = [
  { label: "Email", href: "mailto:mo@mosarhan.io", handle: "mo@mosarhan.io" },
  { label: "LinkedIn", href: "https://linkedin.com/in/mosarhan", handle: "/in/mosarhan" },
  { label: "Dribbble", href: "https://dribbble.com/mosarhan", handle: "@mosarhan" },
  { label: "Read.cv", href: "https://read.cv/mosarhan", handle: "/mosarhan" },
  { label: "X (Twitter)", href: "https://x.com/mosarhan", handle: "@mosarhan" },
];

const services = [
  {
    title: "Embedded design leadership",
    body: "Joining your team for a quarter or two to lead a redesign, mature a system, or hire a permanent design lead.",
  },
  {
    title: "Product audits",
    body: "A 1–2 week deep look at your product with a written report and prioritised list of changes I'd make in your shoes.",
  },
  {
    title: "0→1 design",
    body: "Working with founders to take a product from rough idea to launchable v1 — research, design, prototype, and brand.",
  },
];

const faqs = [
  {
    q: "Where are you based?",
    a: "Cairo, Egypt. I work async with teams across Europe and North America, and travel for kick-offs when it matters.",
  },
  {
    q: "What's your typical engagement length?",
    a: "Most projects run 6–14 weeks. I take on 3–4 engagements per year so I can give each one real attention.",
  },
  {
    q: "Do you work alone?",
    a: "Mostly. For larger scopes I bring in trusted collaborators — engineers, motion designers, researchers — but you'll always work directly with me.",
  },
  {
    q: "Will you sign an NDA?",
    a: "Yes, happily. Just send it over.",
  },
];
---

<Layout title="Contact — Mo Sarhan" description="Start a conversation about a project, an audit, or design leadership.">
  <Nav />

  <main>
    <!-- Hero -->
    <section class="px-6 md:px-10 pt-36 md:pt-44 pb-20 md:pb-24 border-b border-[color:var(--color-line)]">
      <div class="mx-auto max-w-[1280px]">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-8 reveal">
          Contact — Start here
        </div>
        <h1 class="serif text-[44px] leading-[1.05] sm:text-7xl md:text-[104px] md:leading-[0.98] text-balance reveal">
          Let's make something<br/>
          <em class="italic text-[color:var(--color-mute)]">considered.</em>
        </h1>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-12 gap-8">
          <div class="md:col-span-5 reveal">
            <p class="text-[color:var(--color-mute)] leading-relaxed">
              I take on a small number of engagements each quarter — design
              leadership, product audits, and 0→1 projects with founders I
              respect. If that sounds like you, I'd love to hear what you're
              building.
            </p>
            <a
              href="mailto:mo@mosarhan.io"
              class="inline-flex items-center gap-3 mt-8 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-full pl-5 pr-2 py-2 text-sm hover:opacity-90 transition-opacity"
            >
              mo@mosarhan.io
              <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-paper)] text-[color:var(--color-ink)]">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>

          <ul class="md:col-span-6 md:col-start-7 divide-y divide-[color:var(--color-line)] border-y border-[color:var(--color-line)] reveal">
            {socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target={s.href.startsWith("http") ? "_blank" : undefined}
                  rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="group flex items-center justify-between py-5 hover:px-2 transition-[padding] duration-300"
                >
                  <span class="text-sm uppercase tracking-[0.18em] text-[color:var(--color-mute)] group-hover:text-[color:var(--color-ink)]">
                    {s.label}
                  </span>
                  <span class="serif text-2xl flex items-center gap-3">
                    {s.handle}
                    <svg class="opacity-0 group-hover:opacity-100 transition-opacity" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M9 7h8v8"/></svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="mx-auto max-w-[1280px]">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-4 reveal">
          What I take on
        </div>
        <h2 class="serif text-4xl md:text-6xl max-w-3xl mb-16 reveal">Three shapes of work.</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[color:var(--color-line)] border border-[color:var(--color-line)]">
          {services.map((s, i) => (
            <div class="bg-[color:var(--color-paper)] p-8 md:p-10 reveal">
              <div class="serif text-2xl text-[color:var(--color-mute)] mb-6">
                {String(i + 1).padStart(2, "0")}
              </div>
              <h3 class="serif text-2xl md:text-3xl mb-4">{s.title}</h3>
              <p class="text-sm md:text-base text-[color:var(--color-mute)] leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-6 md:px-10 py-24 md:py-32 bg-[color:var(--color-ink)] text-[color:var(--color-paper)]">
      <div class="mx-auto max-w-[1280px] grid grid-cols-1 md:grid-cols-12 gap-10">
        <div class="md:col-span-3 reveal">
          <div class="text-xs uppercase tracking-[0.2em] text-white/50 mb-4">FAQ</div>
          <h2 class="serif text-4xl md:text-5xl">Quick answers.</h2>
        </div>
        <ul class="md:col-span-8 md:col-start-5 reveal">
          {faqs.map((f) => (
            <li class="border-t border-white/15 last:border-b py-6">
              <h3 class="serif text-2xl md:text-3xl mb-3">{f.q}</h3>
              <p class="text-white/70 leading-relaxed max-w-2xl">{f.a}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

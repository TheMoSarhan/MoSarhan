---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const faqs = [
  {
    q: "Where are you based?",
    a: "Cairo, Egypt — and I work async with people across the Middle East, Europe, and North America most days of the week.",
  },
  {
    q: "What do you actually do?",
    a: "Senior product design — the whole arc, from research and information architecture through interface, motion, and the design systems that hold it all together. I also write code well enough to keep engineers honest.",
  },
  {
    q: "Will you reply to my email?",
    a: "Yes — I read everything that lands, and reply to most within a few days. Even if it's just to argue.",
  },
  {
    q: "Can I quote you?",
    a: "Anything written on this site, sure. Just send the link back when it's live.",
  },
];
---

<Layout title="Contact — Muhammed Sarhan" description="Drop me a line — about the work, the writing, or anything you'd want to argue about over coffee.">
  <Nav />

  <main>
    <!-- Hero -->
    <section class="px-6 md:px-10 pt-36 md:pt-44 pb-20 md:pb-28 border-b border-[color:var(--color-line)] relative overflow-hidden">
      <!-- Decorative oversized number -->
      <div class="pointer-events-none select-none absolute -top-8 -right-2 serif text-[28vw] md:text-[18vw] leading-none text-black/[0.035]">
        05
      </div>

      <div class="relative mx-auto max-w-[1280px]">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-8 reveal">
          Contact — Say Hello
        </div>
        <h1 class="serif text-[44px] leading-[1.05] sm:text-7xl md:text-[112px] md:leading-[0.96] tracking-[-0.025em] text-balance">
          <span class="block split">Liked what you saw?</span>
          <span class="block split"><em class="italic text-[color:var(--color-mute)]">My inbox</em> is open.</span>
        </h1>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-12 gap-8 items-end">
          <div class="md:col-span-6 reveal">
            <p class="text-[color:var(--color-mute)] leading-relaxed max-w-md">
              Thoughts on the work, a question about a project, a typo you
              spotted, an opinion you want to argue with — all welcome.
              I read every message and reply to most.
            </p>
          </div>

          <div class="md:col-span-6 md:text-right reveal">
            <a
              href="mailto:mo@mosarhan.io"
              class="serif inline-flex items-baseline gap-3 text-3xl md:text-6xl underline underline-offset-[10px] decoration-1 decoration-[color:var(--color-line)] hover:decoration-[color:var(--color-ink)] transition-colors"
              data-cursor="hover"
            >
              mo@mosarhan.io
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M7 17L17 7M9 7h8v8"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick personal stats card row -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="mx-auto max-w-[1280px] grid grid-cols-2 md:grid-cols-4 gap-px bg-[color:var(--color-line)] border border-[color:var(--color-line)]">
        {[
          ["Cairo, Egypt", "Where to find me"],
          ["GMT+2", "Local time"],
          ["English · Arabic", "Languages"],
          ["~24h", "Average reply"],
        ].map(([k, v]) => (
          <div class="bg-[color:var(--color-paper)] p-8 md:p-10 reveal">
            <div class="serif text-2xl md:text-3xl">{k}</div>
            <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-mute)] mt-3">{v}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-6 md:px-10 py-24 md:py-32 bg-[color:var(--color-ink)] text-[color:var(--color-paper)]" data-cursor-mode="dark">
      <div class="mx-auto max-w-[1280px] grid grid-cols-1 md:grid-cols-12 gap-10">
        <div class="md:col-span-3 reveal">
          <div class="text-xs uppercase tracking-[0.2em] text-white/50 mb-4">FAQ</div>
          <h2 class="serif text-4xl md:text-6xl text-balance">Quick answers.</h2>
        </div>
        <ul class="md:col-span-8 md:col-start-5 reveal">
          {faqs.map((f) => (
            <li class="border-t border-white/15 last:border-b py-8">
              <h3 class="serif text-2xl md:text-3xl mb-3">{f.q}</h3>
              <p class="text-white/70 leading-relaxed max-w-2xl">{f.a}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { withBase } from "../../lib/url";
import { projects, getProject } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProject(slug!)!;
const next = project.next ? getProject(project.next) : undefined;
---

<Layout title={`${project.title} — Mo Sarhan`} description={project.blurb}>
  <Nav />

  <main>
    <!-- Hero -->
    <section class="px-6 md:px-10 pt-36 md:pt-44 pb-20 md:pb-24 border-b border-[color:var(--color-line)]">
      <div class="mx-auto max-w-[1280px]">
        <a href={withBase("/work")} class="inline-flex items-center gap-2 text-sm text-[color:var(--color-mute)] hover:text-[color:var(--color-ink)] mb-10">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M19 12H5M11 19l-7-7 7-7"/></svg>
          All work
        </a>

        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] reveal">
          Case Study {project.n} — {project.year}
        </div>
        <h1 class="serif mt-6 text-[44px] leading-[1.05] sm:text-6xl md:text-[88px] md:leading-[0.98] text-balance reveal">
          {project.title}
        </h1>
        <p class="mt-8 max-w-2xl text-base md:text-lg leading-relaxed text-[color:var(--color-mute)] reveal">
          {project.blurb}
        </p>
      </div>
    </section>

    <!-- Meta strip -->
    <section class="px-6 md:px-10 py-12 border-b border-[color:var(--color-line)]">
      <div class="mx-auto max-w-[1280px] grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          ["Client", project.client],
          ["Role", project.role],
          ["Duration", project.duration],
          ["Team", project.team.join(" · ")],
        ].map(([k, v]) => (
          <div class="reveal">
            <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-mute)] mb-2">{k}</div>
            <div class="text-sm leading-relaxed">{v}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Visual placeholder -->
    <section class="px-6 md:px-10 py-16">
      <div class="mx-auto max-w-[1280px]">
        <div class="aspect-[16/9] bg-[color:var(--color-ink)] rounded-sm relative overflow-hidden reveal">
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="serif text-white/20 text-7xl md:text-9xl select-none">{project.title}</span>
          </div>
          <div class="absolute bottom-4 right-4 text-white/30 text-xs uppercase tracking-widest">
            Visual placeholder — replace with real imagery
          </div>
        </div>
      </div>
    </section>

    <!-- Context -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="mx-auto max-w-[1280px] grid grid-cols-1 md:grid-cols-12 gap-10">
        <div class="md:col-span-3 reveal">
          <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">01 — Context</div>
        </div>
        <div class="md:col-span-8 md:col-start-5 space-y-8 reveal">
          <h2 class="serif text-3xl md:text-5xl">The brief, in plain terms.</h2>
          <p class="text-lg leading-relaxed text-[color:var(--color-mute)]">{project.context}</p>
          <div class="border-l-2 border-[color:var(--color-ink)] pl-6 py-2">
            <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-mute)] mb-3">The challenge</div>
            <p class="text-base md:text-lg leading-relaxed">{project.challenge}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Approach -->
    <section class="px-6 md:px-10 py-24 md:py-32 bg-[color:var(--color-ink)] text-[color:var(--color-paper)]">
      <div class="mx-auto max-w-[1280px] grid grid-cols-1 md:grid-cols-12 gap-10">
        <div class="md:col-span-3 reveal">
          <div class="text-xs uppercase tracking-[0.2em] text-white/50">02 — Approach</div>
        </div>
        <div class="md:col-span-8 md:col-start-5 reveal">
          <h2 class="serif text-3xl md:text-5xl mb-12">How I broke down the problem.</h2>
          <ol class="space-y-8">
            {project.approach.map((step, i) => (
              <li class="flex gap-6 border-t border-white/15 pt-6">
                <span class="serif text-2xl text-white/40 shrink-0">{String(i + 1).padStart(2, "0")}</span>
                <p class="text-base md:text-lg leading-relaxed text-white/80">{step}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="px-6 md:px-10 py-24 md:py-32 border-b border-[color:var(--color-line)]">
      <div class="mx-auto max-w-[1280px] grid grid-cols-1 md:grid-cols-12 gap-10">
        <div class="md:col-span-3 reveal">
          <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">03 — Deliverables</div>
        </div>
        <ul class="md:col-span-8 md:col-start-5 divide-y divide-[color:var(--color-line)] border-y border-[color:var(--color-line)] reveal">
          {project.deliverables.map((d) => (
            <li class="py-5 serif text-2xl md:text-3xl">{d}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Outcomes -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="mx-auto max-w-[1280px]">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-10 reveal">04 — Outcomes</div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[color:var(--color-line)] border border-[color:var(--color-line)]">
          {project.outcomes.map((o) => (
            <div class="bg-[color:var(--color-paper)] p-8 md:p-10 reveal">
              <div class="serif text-5xl md:text-6xl">{o.metric}</div>
              <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-mute)] mt-3">{o.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Reflection -->
    <section class="px-6 md:px-10 py-24 md:py-32 border-t border-[color:var(--color-line)]">
      <div class="mx-auto max-w-[1280px]">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-8 reveal">05 — Reflection</div>
        <blockquote class="serif text-3xl md:text-5xl max-w-4xl leading-tight reveal">
          “{project.reflection}”
        </blockquote>
      </div>
    </section>

    <!-- Next project -->
    {next && (
      <section class="border-t border-[color:var(--color-line)]">
        <a href={withBase(`/work/${next.slug}`)} class="group block px-6 md:px-10 py-20 md:py-32 transition-colors hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)]">
          <div class="mx-auto max-w-[1280px]">
            <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/60 mb-6">
              Next project — {next.n}
            </div>
            <div class="flex items-end justify-between gap-8 flex-wrap">
              <h2 class="serif text-5xl md:text-8xl">{next.title}</h2>
              <span class="text-sm flex items-center gap-3">
                Continue
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      </section>
    )}
  </main>

  <Footer />
</Layout>

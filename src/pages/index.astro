---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Industries from "../components/Industries.astro";
import BigStatement from "../components/BigStatement.astro";
import Work from "../components/Work.astro";
import Mosaic from "../components/Mosaic.astro";
import About from "../components/About.astro";
import Approach from "../components/Approach.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "moSarhan.io",
  "alternateName": "Muhammed Sarhan — Portfolio",
  "url": "https://mosarhan.io",
  "inLanguage": "en",
  "author": { "@type": "Person", "name": "Muhammed Sarhan" },
};

const profileLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "url": "https://mosarhan.io",
  "mainEntity": {
    "@type": "Person",
    "name": "Muhammed Sarhan",
    "alternateName": ["Mo Sarhan", "moSarhan"],
    "jobTitle": "Senior Product Designer",
    "url": "https://mosarhan.io",
    "image": "https://mosarhan.io/og.svg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cairo",
      "addressCountry": "EG",
    },
  },
};
---

<Layout
  title="Muhammed Sarhan — Senior Product Designer (UI/UX) · Cairo, Egypt"
  description="Personal archive of Muhammed Sarhan — a senior product designer in Cairo. 14+ years, 50+ products, three continents. UI/UX work across fintech, healthcare, e-commerce, and digital media."
  type="profile"
  jsonLd={[websiteLd, profileLd]}
>
  <Nav />
  <main id="top">
    <Hero />
    <Industries />
    <BigStatement />
    <Work />
    <Mosaic />
    <About />
    <Approach />
    <Contact />
  </main>
  <Footer />
</Layout>

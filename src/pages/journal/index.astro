---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import { withBase } from "../../lib/url";
import { posts } from "../../data/posts";

const sorted = [...posts].sort((a, b) => b.date.localeCompare(a.date));
const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" });
---

<Layout
  title="Journal — Notes on Craft by Muhammed Sarhan"
  description="Short writing on product design — craft, process, restraint, and the decisions behind the work. By Muhammed Sarhan, senior product designer in Cairo."
  keywords="design writing, product design notes, design process, Muhammed Sarhan blog, design craft, design philosophy"
>
  <Nav />

  <main id="main-content">
    <PageHero eyebrow="Journal — Notes">
      <Fragment slot="title">
        Short writing,<br/>
        mostly about <em class="italic text-[color:var(--color-mute)]">craft</em>.
      </Fragment>
      <Fragment slot="intro">
        Occasional notes on design, process, and the decisions behind the
        work. Written when something is worth saying, never on a schedule.
      </Fragment>
    </PageHero>

    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="mx-auto max-w-[1280px]">
        <ul class="border-t border-[color:var(--color-line)]">
          {sorted.map((p, i) => (
            <li class="border-b border-[color:var(--color-line)] reveal">
              <a
                href={withBase(`/journal/${p.slug}`)}
                class="group grid grid-cols-12 gap-4 md:gap-8 items-baseline py-10 md:py-12 px-2 md:px-6 -mx-2 md:-mx-6 transition-colors hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)]"
              >
                <span class="col-span-2 md:col-span-1 text-xs tracking-widest text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/60">
                  {String(sorted.length - i).padStart(2, "0")}
                </span>
                <div class="col-span-10 md:col-span-7">
                  <h2 class="serif text-3xl md:text-5xl mb-3">{p.title}</h2>
                  <p class="text-sm md:text-base text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/70 max-w-xl">
                    {p.excerpt}
                  </p>
                </div>
                <div class="hidden md:block md:col-span-2 text-sm text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/70">
                  {p.tag}
                </div>
                <div class="col-span-12 md:col-span-2 md:text-right text-sm text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/70">
                  {fmt(p.date)} · {p.readingMinutes} min
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

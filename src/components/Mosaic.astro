---
---

<section class="px-6 md:px-10 py-24 md:py-32">
  <div class="mx-auto max-w-[1280px]">
    <div class="flex items-end justify-between gap-8 mb-12 md:mb-16">
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-4 reveal">
          Sketchbook
        </div>
        <h2 class="serif text-5xl md:text-7xl reveal text-balance">
          Recent <em class="italic">studies</em>, sketches,<br/>and side quests.
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-12 grid-rows-2 gap-4 md:gap-6 auto-rows-[minmax(180px,_1fr)]">
      <!-- Tile 1: typographic -->
      <div class="col-span-12 md:col-span-7 row-span-1 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-sm p-8 md:p-12 flex items-end justify-between min-h-[320px] md:min-h-[420px] relative overflow-hidden lift" data-cursor-mode="dark" data-cursor="hover">
        <div class="absolute inset-0 tile-grid opacity-50"></div>
        <div class="relative">
          <div class="text-xs uppercase tracking-[0.2em] text-white/50 mb-4">Type Specimen — 2026</div>
          <div class="serif italic text-7xl md:text-[140px] leading-none">Aa</div>
        </div>
        <div class="relative serif text-2xl md:text-4xl text-white/80 max-w-xs">
          A type system designed for clarity at every scale.
        </div>
      </div>

      <!-- Tile 2: monogram circle -->
      <div class="col-span-6 md:col-span-5 row-span-1 bg-[color:var(--color-paper)] border border-[color:var(--color-line)] rounded-sm p-6 md:p-10 flex flex-col justify-between min-h-[320px] md:min-h-[420px] lift" data-cursor="hover">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">Identity — 2025</div>
        <div class="flex justify-center">
          <svg aria-hidden="true" viewBox="0 0 200 200" class="w-40 h-40 md:w-52 md:h-52">
            <circle cx="100" cy="100" r="98" fill="none" stroke="#0a0a0a" stroke-width="1"/>
            <circle cx="100" cy="100" r="72" fill="#0a0a0a"/>
            <text x="50%" y="58%" text-anchor="middle" font-family="Instrument Serif" font-style="italic" font-size="80" fill="#f6f5f2">m</text>
          </svg>
        </div>
        <div class="serif text-xl md:text-2xl">A mark with patience.</div>
      </div>

      <!-- Tile 3: dotted dark -->
      <div class="col-span-6 md:col-span-3 row-span-1 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-sm p-6 md:p-8 flex flex-col justify-between min-h-[260px] relative overflow-hidden lift" data-cursor-mode="dark" data-cursor="hover">
        <div class="absolute inset-0 tile-dots"></div>
        <div class="relative text-xs uppercase tracking-[0.2em] text-white/50">Process</div>
        <div class="relative serif text-3xl md:text-4xl">Make to think — never deck to decide.</div>
      </div>

      <!-- Tile 4: blueprint stripes -->
      <div class="col-span-12 md:col-span-5 row-span-1 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-sm relative overflow-hidden min-h-[260px] lift" data-cursor-mode="dark" data-cursor="hover">
        <div class="absolute inset-0 tile-stripes opacity-30"></div>
        <div class="relative h-full p-6 md:p-10 flex flex-col justify-between">
          <div class="text-xs uppercase tracking-[0.2em] text-white/50">Wireframe — Sketch No. 04</div>
          <div class="serif text-3xl md:text-5xl max-w-md">Every screen is a scaffold for a sentence the user is trying to say.</div>
        </div>
      </div>

      <!-- Tile 5: list -->
      <div class="col-span-12 md:col-span-4 row-span-1 bg-[color:var(--color-paper)] border border-[color:var(--color-line)] rounded-sm p-6 md:p-8 flex flex-col justify-between min-h-[260px] lift" data-cursor="hover">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-4">Currently in the lab</div>
        <ul class="space-y-3 text-base md:text-lg serif">
          <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-mute)] text-xs">01</span> Voice-first onboarding for fintech</li>
          <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-mute)] text-xs">02</span> Token-driven motion language</li>
          <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-mute)] text-xs">03</span> A small CMS for designers</li>
          <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-mute)] text-xs">04</span> Arabic-first type primer</li>
        </ul>
        <div class="mt-6 text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">Selected experiments</div>
      </div>
    </div>
  </div>
</section>

---
const year = new Date().getFullYear();
---

<footer class="px-6 md:px-10 pt-16 pb-10 border-t border-[color:var(--color-line)]">
  <div class="mx-auto max-w-[1280px]">
    <div class="serif text-[18vw] md:text-[14vw] leading-[0.85] tracking-tight select-none">
      moSarhan<span class="text-[color:var(--color-mute)]">.io</span>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 text-sm text-[color:var(--color-mute)]">
      <div>© {year} Mo Sarhan. All rights reserved.</div>
      <div class="md:text-center">
        Cairo, Egypt — <span id="clock">—:—</span>
      </div>
      <div class="md:text-right">
        Designed & built with care.
        <a href="#top" class="ml-2 underline underline-offset-4 hover:text-[color:var(--color-ink)]">Back to top ↑</a>
      </div>
    </div>
  </div>
</footer>

---
const items = [
  "Fintech",
  "Healthcare",
  "E-commerce",
  "Digital Media",
  "EdTech",
  "On-demand",
  "SaaS",
  "Government",
  "Travel",
  "Web3",
];
const loop = [...items, ...items];
---

<section class="border-y border-[color:var(--color-line)] py-10 md:py-12 overflow-hidden bg-white/30">
  <div class="px-6 md:px-10 max-w-[1280px] mx-auto flex items-center gap-6 mb-8 reveal">
    <span class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">
      Industries served
    </span>
    <span class="flex-1 h-px bg-[color:var(--color-line)]"></span>
    <span class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">
      14 years · 3 continents
    </span>
  </div>

  <div class="flex gap-14 whitespace-nowrap marquee-track w-max">
    {loop.map((t, i) => (
      <span class="serif text-4xl md:text-6xl flex items-center gap-14 text-[color:var(--color-ink)]">
        <span class="text-[color:var(--color-mute)] text-base">{String((i % items.length) + 1).padStart(2, "0")}</span>
        {t}
      </span>
    ))}
  </div>
</section>

---
import { withBase } from "../lib/url";
import { projects } from "../data/projects";
---

<section id="work" class="px-6 md:px-10 py-24 md:py-32">
  <div class="mx-auto max-w-[1280px]">
    <div class="flex items-end justify-between gap-8 mb-12 md:mb-16">
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-4 reveal">
          Selected Work
        </div>
        <h2 class="serif text-5xl md:text-7xl reveal">A decade in <em class="italic">edits</em>.</h2>
      </div>
      <a href={withBase("/work")} class="hidden md:inline text-sm underline underline-offset-4 text-[color:var(--color-mute)] hover:text-[color:var(--color-ink)]">
        View all projects →
      </a>
    </div>

    <ul class="border-t border-[color:var(--color-line)]">
      {projects.map((p) => (
        <li class="group border-b border-[color:var(--color-line)] reveal">
          <a href={withBase(`/work/${p.slug}`)} class="grid grid-cols-12 gap-4 md:gap-8 items-center py-8 md:py-10 transition-colors hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)] px-2 md:px-6 -mx-2 md:-mx-6">
            <span class="col-span-2 md:col-span-1 text-xs tracking-widest text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/60">
              {p.n}
            </span>
            <span class="serif col-span-10 md:col-span-4 text-2xl md:text-4xl">
              {p.title}
            </span>
            <span class="hidden md:block md:col-span-3 text-sm text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/70">
              {p.tag}
            </span>
            <span class="hidden md:block md:col-span-3 text-sm text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/70">
              {p.blurb}
            </span>
            <span class="col-span-12 md:col-span-1 md:text-right text-sm text-[color:var(--color-mute)] group-hover:text-[color:var(--color-paper)]/70">
              {p.year}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

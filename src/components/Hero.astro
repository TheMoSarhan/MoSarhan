---
---

<section id="top" class="relative pt-40 md:pt-48 pb-24 md:pb-32 px-6 md:px-10">
  <div class="mx-auto max-w-[1280px]">
    <div class="flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] reveal">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
      Available for select engagements — 2026
    </div>

    <h1 class="serif mt-8 text-[44px] leading-[1.05] sm:text-7xl md:text-[104px] md:leading-[0.98] reveal">
      Designing calm,<br/>
      <em class="italic text-[color:var(--color-mute)]">considered</em> products<br/>
      for an over-designed web.
    </h1>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-10">
      <p class="md:col-span-6 md:col-start-7 text-base md:text-lg leading-relaxed text-[color:var(--color-mute)] reveal">
        I'm <span class="text-[color:var(--color-ink)]">Mo Sarhan</span> — a lead product
        designer working at the intersection of brand, interface, and systems thinking.
        For a decade I've helped founders and teams turn ambitious ideas into products
        people actually want to use.
      </p>
    </div>

    <div class="mt-16 flex flex-wrap items-center gap-4 reveal">
      <a
        href="#work"
        class="group inline-flex items-center gap-3 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-full pl-5 pr-2 py-2 text-sm hover:opacity-90 transition-opacity"
      >
        See selected work
        <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-paper)] text-[color:var(--color-ink)] group-hover:translate-x-0.5 transition-transform">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
      <a href="#contact" class="text-sm underline underline-offset-4 decoration-[color:var(--color-line)] hover:decoration-[color:var(--color-ink)]">
        Or start a conversation
      </a>
    </div>
  </div>

  <!-- Hairline divider with running stats -->
  <div class="mx-auto max-w-[1280px] mt-24 md:mt-32 grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-[color:var(--color-line)] pt-8">
    {[
      ["10+", "Years designing"],
      ["40+", "Shipped products"],
      ["12", "Industries"],
      ["4", "Continents"],
    ].map(([k, v]) => (
      <div class="reveal">
        <div class="serif text-4xl md:text-5xl">{k}</div>
        <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-mute)] mt-2">{v}</div>
      </div>
    ))}
  </div>
</section>

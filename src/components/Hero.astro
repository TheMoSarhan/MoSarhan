---
---

<section id="hero-parallax" class="relative pt-32 md:pt-40 pb-20 md:pb-28 px-6 md:px-10 overflow-hidden">
  <!-- Faint background grid -->
  <div class="parallax pointer-events-none absolute inset-0 opacity-[0.05]" data-depth="6">
    <div class="absolute inset-0"
      style="background-image:linear-gradient(to right, #000 1px, transparent 1px), linear-gradient(to bottom, #000 1px, transparent 1px); background-size: 96px 96px;">
    </div>
  </div>

  <!-- Floating monogram (visual placeholder for portrait) -->
  <div class="parallax pointer-events-none absolute -right-12 top-32 md:right-[6%] md:top-32 hidden md:block" data-depth="-22">
    <svg viewBox="0 0 400 400" class="w-[420px] h-[420px] xl:w-[560px] xl:h-[560px] opacity-90">
      <defs>
        <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#0a0a0a"/>
          <stop offset="100%" stop-color="#2c2c2c"/>
        </linearGradient>
      </defs>
      <circle cx="200" cy="200" r="198" fill="url(#g)"/>
      <text x="50%" y="58%" text-anchor="middle"
            font-family="Instrument Serif, serif" font-style="italic"
            font-size="280" fill="#f6f5f2">m</text>
      <circle cx="200" cy="200" r="196" fill="none" stroke="#f6f5f2" stroke-opacity="0.08" stroke-width="1"/>
    </svg>
  </div>

  <div class="relative mx-auto max-w-[1280px]">
    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] reveal">
      <span class="w-8 h-px bg-[color:var(--color-mute)]"></span>
      Senior Product Designer
      <span class="w-8 h-px bg-[color:var(--color-mute)]"></span>
    </div>

    <!-- Big serif headline with split-word reveal -->
    <h1 class="serif mt-10 text-[40px] leading-[1.04] sm:text-7xl md:text-[112px] md:leading-[0.96] tracking-[-0.025em] text-balance">
      <span class="block split">Fourteen years</span>
      <span class="block split"><em class="italic text-[color:var(--color-mute)]">designing</em> calm,</span>
      <span class="block split">considered software.</span>
    </h1>

    <!-- Subheadline -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-6 md:col-start-1 reveal">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-4">
          Muhammed Sarhan — Cairo, Egypt
        </div>
        <p class="text-base md:text-lg leading-relaxed text-[color:var(--color-mute)] max-w-lg">
          Fourteen years designing at the intersection of brand, interface,
          and systems — for teams across three continents, in fintech,
          healthcare, e-commerce, and digital media. This is a small
          archive of the work and the thinking behind it.
        </p>
      </div>

      <div class="md:col-span-4 md:col-start-9 flex md:items-end md:justify-end reveal">
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="#work"
            class="group inline-flex items-center gap-3 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-full pl-5 pr-2 py-2 text-sm hover:opacity-90 transition-opacity"
            data-cursor="hover"
          >
            Enter the archive
            <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-paper)] text-[color:var(--color-ink)] group-hover:translate-x-0.5 transition-transform">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="relative mx-auto max-w-[1280px] mt-24 md:mt-32 grid grid-cols-2 md:grid-cols-4 gap-y-8 border-t border-[color:var(--color-line)] pt-10">
    {[
      ["14+", "Years designing"],
      ["50+", "Products shipped"],
      ["3", "Continents served"],
      ["12", "Industries explored"],
    ].map(([k, v]) => (
      <div class="reveal">
        <div class="serif text-5xl md:text-6xl tracking-tight">{k}</div>
        <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-mute)] mt-3">{v}</div>
      </div>
    ))}
  </div>

  <!-- Scroll hint -->
  <div class="relative mx-auto max-w-[1280px] mt-20 flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">
    <span>Scroll</span>
    <span class="w-12 h-px bg-[color:var(--color-mute)]"></span>
    <span>The work below</span>
  </div>
</section>

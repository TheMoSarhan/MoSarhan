---
---

<section id="hero-parallax" class="relative pt-32 md:pt-40 pb-20 md:pb-28 px-6 md:px-10 overflow-hidden">
  <!-- Faint background grid -->
  <div class="parallax pointer-events-none absolute inset-0 opacity-[0.05]" data-depth="6">
    <div class="absolute inset-0"
      style="background-image:linear-gradient(to right, var(--color-ink) 1px, transparent 1px), linear-gradient(to bottom, var(--color-ink) 1px, transparent 1px); background-size: 96px 96px;">
    </div>
  </div>

  <!-- Floating precision mark (decorative) -->
  <div class="parallax pointer-events-none absolute -right-16 top-20 md:right-[3%] md:top-20 hidden md:block" data-depth="-22">
    <svg
      aria-hidden="true"
      viewBox="0 0 480 480"
      class="w-[400px] h-[400px] xl:w-[500px] xl:h-[500px] opacity-[0.13]"
      fill="none"
      stroke="var(--color-ink)"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <!-- Outer ring -->
      <circle cx="240" cy="240" r="228" stroke-width="0.8"/>
      <!-- Concentric rings -->
      <circle cx="240" cy="240" r="171" stroke-width="0.5" stroke-opacity="0.7"/>
      <circle cx="240" cy="240" r="114" stroke-width="0.5" stroke-opacity="0.5"/>
      <circle cx="240" cy="240" r="57"  stroke-width="0.5" stroke-opacity="0.4"/>
      <!-- Crosshairs -->
      <line x1="12"  y1="240" x2="468" y2="240" stroke-width="0.5" stroke-opacity="0.75"/>
      <line x1="240" y1="12"  x2="240" y2="468" stroke-width="0.5" stroke-opacity="0.75"/>
      <!-- 45° diagonals -->
      <line x1="79"  y1="79"  x2="401" y2="401" stroke-width="0.4" stroke-opacity="0.45"/>
      <line x1="401" y1="79"  x2="79"  y2="401" stroke-width="0.4" stroke-opacity="0.45"/>
      <!-- Cardinal tick marks -->
      <line x1="468" y1="240" x2="448" y2="240" stroke-width="1.5"/>
      <line x1="240" y1="12"  x2="240" y2="32"  stroke-width="1.5"/>
      <line x1="12"  y1="240" x2="32"  y2="240" stroke-width="1.5"/>
      <line x1="240" y1="468" x2="240" y2="448" stroke-width="1.5"/>
      <!-- 30° interval ticks -->
      <line x1="437.4" y1="354.0" x2="425.3" y2="347.0" stroke-width="0.75"/>
      <line x1="354.0" y1="437.4" x2="347.0" y2="425.3" stroke-width="0.75"/>
      <line x1="126.0" y1="437.4" x2="133.0" y2="425.3" stroke-width="0.75"/>
      <line x1="42.6"  y1="354.0" x2="54.7"  y2="347.0" stroke-width="0.75"/>
      <line x1="42.6"  y1="126.0" x2="54.7"  y2="133.0" stroke-width="0.75"/>
      <line x1="126.0" y1="42.6"  x2="133.0" y2="54.7"  stroke-width="0.75"/>
      <line x1="354.0" y1="42.6"  x2="347.0" y2="54.7"  stroke-width="0.75"/>
      <line x1="437.4" y1="126.0" x2="425.3" y2="133.0" stroke-width="0.75"/>
      <!-- Dot markers at diagonal × middle-ring intersections -->
      <circle cx="360.9" cy="360.9" r="2.5" fill="var(--color-ink)" stroke="none"/>
      <circle cx="119.1" cy="360.9" r="2.5" fill="var(--color-ink)" stroke="none"/>
      <circle cx="119.1" cy="119.1" r="2.5" fill="var(--color-ink)" stroke="none"/>
      <circle cx="360.9" cy="119.1" r="2.5" fill="var(--color-ink)" stroke="none"/>
      <!-- Center marker -->
      <circle cx="240" cy="240" r="12"  stroke-width="0.75"/>
      <circle cx="240" cy="240" r="3.5" fill="var(--color-ink)" stroke="none"/>
    </svg>
  </div>

  <div class="relative mx-auto max-w-[1280px]">
    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] reveal">
      <span class="w-8 h-px bg-[color:var(--color-mute)]"></span>
      Senior Product Designer
      <span class="w-8 h-px bg-[color:var(--color-mute)]"></span>
    </div>

    <!-- Big serif headline with split-word reveal -->
    <h1 class="serif mt-10 text-[40px] leading-[1.04] sm:text-7xl md:text-[112px] md:leading-[0.96] tracking-[-0.025em] text-balance">
      <span class="block split">Fourteen years</span>
      <span class="block split"><em class="italic text-[color:var(--color-mute)]">designing</em> calm,</span>
      <span class="block split">considered software.</span>
    </h1>

    <!-- Subheadline -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-6 md:col-start-1 reveal">
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-4">
          Muhammed Sarhan — Cairo, Egypt
        </div>
        <p class="text-base md:text-lg leading-relaxed text-[color:var(--color-mute)] max-w-lg">
          Fourteen years designing at the intersection of brand, interface,
          and systems — for teams across three continents, in fintech,
          healthcare, e-commerce, and digital media. This is a small
          archive of the work and the thinking behind it.
        </p>
      </div>

      <div class="md:col-span-4 md:col-start-9 flex md:items-end md:justify-end reveal">
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="#work"
            class="group inline-flex items-center gap-3 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-full pl-5 pr-2 py-2 text-sm hover:opacity-90 transition-opacity"
            data-cursor="hover"
          >
            Enter the archive
            <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-paper)] text-[color:var(--color-ink)] group-hover:translate-x-0.5 transition-transform">
              <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="relative mx-auto max-w-[1280px] mt-24 md:mt-32 grid grid-cols-2 md:grid-cols-4 gap-y-8 border-t border-[color:var(--color-line)] pt-10">
    {[
      ["14+", "Years designing"],
      ["50+", "Products shipped"],
      ["3", "Continents served"],
      ["12", "Industries explored"],
    ].map(([k, v]) => (
      <div class="reveal">
        <div class="serif text-5xl md:text-6xl tracking-tight">{k}</div>
        <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mt-3">{v}</div>
      </div>
    ))}
  </div>

  <!-- Scroll hint -->
  <div class="relative mx-auto max-w-[1280px] mt-20 flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)]">
    <span>Scroll</span>
    <span class="w-12 h-px bg-[color:var(--color-mute)]"></span>
    <span>The work below</span>
  </div>
</section>

---
interface Props {
  n: string;
  dark?: boolean;
  class?: string;
}
const { n, dark = false, class: className = "" } = Astro.props;
---

<div
  aria-hidden="true"
  class:list={[
    "pointer-events-none select-none absolute serif text-[28vw] leading-none",
    dark ? "text-white/[0.04]" : "text-black/[0.035]",
    className,
  ]}
>
  {n}
</div>

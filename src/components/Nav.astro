---
import { withBase } from "../lib/url";

const links = [
  { href: withBase("/work"), label: "Work" },
  { href: withBase("/about"), label: "About" },
  { href: withBase("/journal"), label: "Journal" },
  { href: withBase("/contact"), label: "Contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-[color:var(--color-paper)]/70 border-b border-[color:var(--color-line)]">
  <nav class="mx-auto max-w-[1280px] px-6 md:px-10 h-14 flex items-center justify-between">
    <a href={withBase("/")} class="font-medium tracking-tight text-sm">
      mo<span class="text-[color:var(--color-mute)]">sarhan</span>.io
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm text-[color:var(--color-mute)]">
      {links.map((l) => {
        const active = currentPath === l.href.replace(/\/$/, "");
        return (
          <li>
            <a
              href={l.href}
              class:list={[
                "hover:text-[color:var(--color-ink)] transition-colors",
                active && "text-[color:var(--color-ink)]",
              ]}
            >
              {l.label}
            </a>
          </li>
        );
      })}
    </ul>

    <a
      href={withBase("/contact")}
      class="text-sm border border-[color:var(--color-ink)] px-3 py-1.5 rounded-full hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)] transition-colors"
    >
      Get in touch
    </a>
  </nav>
</header>

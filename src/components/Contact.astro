---
---

<section id="contact" class="px-6 md:px-10 py-24 md:py-40 relative">
  <div class="mx-auto max-w-[1280px]">
    <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-6 reveal">
      05 — Say Hello
    </div>

    <h2 class="serif text-[56px] leading-[1.02] sm:text-7xl md:text-[140px] md:leading-[0.92] tracking-[-0.025em] text-balance">
      <span class="block split">Ready to talk?</span>
      <span class="block split"><em class="italic text-[color:var(--color-mute)]">My inbox</em> is open.</span>
    </h2>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-12 gap-8 items-end">
      <div class="md:col-span-6 reveal">
        <p class="text-[color:var(--color-mute)] leading-relaxed max-w-md">
          Thoughts on the work, a question about a project, an opinion you
          want to argue with — all welcome. I read every message and reply
          to most.
        </p>
      </div>

      <div class="md:col-span-6 md:text-right reveal">
        <a
          href="mailto:mo@mosarhan.io"
          class="serif inline-flex items-baseline gap-3 text-3xl md:text-6xl underline underline-offset-[10px] decoration-1 decoration-[color:var(--color-line)] hover:decoration-[color:var(--color-ink)] transition-colors"
          data-cursor="hover"
        >
          mo@mosarhan.io
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

---
const socials = [
  { label: "Email", href: "mailto:mo@mosarhan.io", handle: "mo@mosarhan.io" },
  { label: "LinkedIn", href: "https://linkedin.com/in/mosarhan", handle: "/in/mosarhan" },
  { label: "Dribbble", href: "https://dribbble.com/mosarhan", handle: "@mosarhan" },
  { label: "Read.cv", href: "https://read.cv/mosarhan", handle: "/mosarhan" },
];
---

<section id="contact" class="px-6 md:px-10 py-24 md:py-40">
  <div class="mx-auto max-w-[1280px]">
    <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-mute)] mb-6 reveal">
      Contact — 01
    </div>

    <h2 class="serif text-[56px] leading-[1.02] sm:text-7xl md:text-[120px] md:leading-[0.95] reveal">
      Have a project<br/>
      in mind? <em class="italic text-[color:var(--color-mute)]">Let's talk.</em>
    </h2>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-5 reveal">
        <p class="text-[color:var(--color-mute)] leading-relaxed">
          I take on a small number of engagements each quarter — design leadership,
          product audits, and 0→1 projects with founders I respect. If that
          sounds like you, I'd love to hear what you're building.
        </p>
        <a
          href="mailto:mo@mosarhan.io"
          class="inline-flex items-center gap-3 mt-8 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded-full pl-5 pr-2 py-2 text-sm hover:opacity-90 transition-opacity"
        >
          Start a project
          <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-paper)] text-[color:var(--color-ink)]">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>

      <ul class="md:col-span-6 md:col-start-7 divide-y divide-[color:var(--color-line)] border-y border-[color:var(--color-line)] reveal">
        {socials.map((s) => (
          <li>
            <a
              href={s.href}
              target={s.href.startsWith("http") ? "_blank" : undefined}
              rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="group flex items-center justify-between py-5 hover:px-2 transition-[padding] duration-300"
            >
              <span class="text-sm uppercase tracking-[0.18em] text-[color:var(--color-mute)] group-hover:text-[color:var(--color-ink)]">
                {s.label}
              </span>
              <span class="serif text-2xl flex items-center gap-3">
                {s.handle}
                <svg class="opacity-0 group-hover:opacity-100 transition-opacity" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

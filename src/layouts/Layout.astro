---
import "../styles/global.css";
import Cursor from "../components/Cursor.astro";

interface Props {
  title?: string;
  description?: string;
  /** Path to OG image relative to site root, e.g. "/og.svg" */
  image?: string;
  /** "website" | "article" | "profile" */
  type?: "website" | "article" | "profile";
  /** ISO date for articles */
  publishedTime?: string;
  /** Optional comma-list of keywords */
  keywords?: string;
  /** Optional JSON-LD object(s) — will be serialized into a script tag */
  jsonLd?: object | object[];
  /** Override the canonical URL (otherwise derived from Astro.url) */
  canonical?: string;
}

const {
  title = "Muhammed Sarhan — Senior Product Designer (UI/UX) · Cairo, Egypt",
  description = "Muhammed Sarhan is a senior product designer based in Cairo, Egypt. 14+ years and 50+ shipped products across three continents — fintech, healthcare, e-commerce, and digital media. Designed with restraint, shipped with intent.",
  image = "/og.svg",
  type = "website",
  publishedTime,
  keywords = "Muhammed Sarhan, Mo Sarhan, mosarhan, mosarhan.io, product designer Cairo, UI UX designer Egypt, senior product designer, design portfolio",
  jsonLd,
  canonical,
} = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, "") ?? "https://mosarhan.io";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(image, siteUrl).href;

const baseOrgLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Muhammed Sarhan",
  "alternateName": ["Mo Sarhan", "moSarhan"],
  "url": siteUrl,
  "image": ogImageUrl,
  "jobTitle": "Senior Product Designer",
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Cairo",
    "addressCountry": "EG",
  },
  "knowsLanguage": ["en", "ar"],
  "knowsAbout": [
    "Product design",
    "UX design",
    "UI design",
    "Design systems",
    "Brand identity",
    "Prototyping",
    "Design leadership",
  ],
  "email": "mailto:mo@mosarhan.io",
};

const allLd = jsonLd
  ? Array.isArray(jsonLd)
    ? [baseOrgLd, ...jsonLd]
    : [baseOrgLd, jsonLd]
  : [baseOrgLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Muhammed Sarhan" />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="light" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="moSarhan.io" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Muhammed Sarhan — Senior Product Designer, Cairo, Egypt" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {publishedTime && <meta property="article:author" content="Muhammed Sarhan" />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Muhammed Sarhan — Senior Product Designer, Cairo, Egypt" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(allLd)} />
  </head>
  <body class="grain">
    <Cursor />
    <slot />

    <script>
      // ------- Reveal-on-scroll -------
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      // ------- Split-text reveal -------
      document.querySelectorAll<HTMLElement>(".split").forEach((node) => {
        const text = node.textContent || "";
        node.innerHTML = "";
        const words = text.trim().split(/\s+/);
        words.forEach((word, i) => {
          const wrap = document.createElement("span");
          wrap.className = "split-word";
          wrap.style.setProperty("--i", String(i));
          const inner = document.createElement("span");
          inner.textContent = word;
          wrap.appendChild(inner);
          node.appendChild(wrap);
          if (i < words.length - 1) node.appendChild(document.createTextNode(" "));
        });
        node.classList.add("split-line");
      });
      document.querySelectorAll(".split-line").forEach((el) => io.observe(el));

      // ------- Cairo clock -------
      const clockEl = document.getElementById("clock");
      if (clockEl) {
        const tick = () => {
          const now = new Date().toLocaleTimeString("en-GB", {
            hour: "2-digit",
            minute: "2-digit",
            timeZone: "Africa/Cairo",
          });
          clockEl.textContent = `${now} CAI`;
        };
        tick();
        setInterval(tick, 1000 * 30);
      }

      // ------- Hero parallax -------
      const heroEl = document.getElementById("hero-parallax");
      if (heroEl && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
        const targets = heroEl.querySelectorAll<HTMLElement>(".parallax");
        const onMove = (e: MouseEvent) => {
          const rect = heroEl.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          targets.forEach((t) => {
            const depth = parseFloat(t.dataset.depth || "10");
            t.style.transform = `translate3d(${x * depth}px, ${y * depth}px, 0)`;
          });
        };
        heroEl.addEventListener("mousemove", onMove);
      }

      // ------- Footer wordmark scroll-scale -------
      const wordmark = document.getElementById("footer-wordmark");
      if (wordmark) {
        const onScroll = () => {
          const rect = wordmark.getBoundingClientRect();
          const v = window.innerHeight;
          const p = Math.max(0, Math.min(1, 1 - rect.top / v));
          wordmark.style.transform = `scale(${0.94 + p * 0.06})`;
          wordmark.style.opacity = String(0.65 + p * 0.35);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }
    </script>
  </body>
</html>
